{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 720,
  "height": 420,
  "background": "#fafaf7",
  "data": {"url": "../data/city_monthly_tmax.csv"},
  "mark": {
    "type": "boxplot",
    "extent": 1.5,
    "size": 38,
    "color": "#ADD8E6",
    "median": {"color": "#1a1a1a", "size": 2.5}
  },
  "encoding": {
    "x": {
      "field": "city",
      "type": "nominal",
      "title": null,
      "sort": ["Darwin", "Brisbane", "Perth", "Sydney", "Adelaide", "Canberra", "Melbourne", "Hobart"],
      "axis": {"labelFontSize": 12, "labelFontWeight": "bold", "labelAngle": 0, "labelPadding": 6}
    },
    "y": {
      "field": "monthly_tmax",
      "type": "quantitative",
      "title": "Monthly mean of daily maximum temperature (°C)",
      "scale": {"domain": [5, 38], "zero": false},
      "axis": {"labelFontSize": 11, "titleFontSize": 12, "grid": true, "gridColor": "#eee"}
    },
    "color": {"value": "#ADD8E6"}
  },
  "config": {
    "view": {"stroke": null},
    "font": "system-ui, -apple-system, Segoe UI, sans-serif",
    "axis": {"domainColor": "#888", "tickColor": "#888"}
  }
}